# Set this to your Elastic Beanstalk backend URL when building for production via Amplify.
# The URL must include /api at the end. Leave blank for local dev (Vite proxy handles /api).
#
# Example (after EB deployment):
#   VITE_API_URL=http://my-env.us-east-1.elasticbeanstalk.com/api
#
# In AWS Amplify console: App settings → Environment variables → add VITE_API_URL
VITE_API_URL=
