# VITE_API_URL controls where the React app sends API requests.
#
# ── Local development ────────────────────────────────────────────────────────
# Leave this EMPTY. Vite's dev server proxies /api/* → http://localhost:5000
# automatically via vite.config.js. No value needed here.
#
# ── Production (AWS Amplify) ─────────────────────────────────────────────────
# Leave this EMPTY as well. Set it to nothing (or omit it entirely) in the
# Amplify console. The default value in api.js falls back to the relative
# path "/api", and Amplify's console rewrite rule proxies /api/* to the
# CloudFront HTTPS URL (which sits in front of Elastic Beanstalk).
#
# DO NOT point this at the raw Elastic Beanstalk HTTP URL directly — browsers
# will block the mixed-content HTTP request from an HTTPS Amplify page, and
# the request bypasses the CloudFront HTTPS layer entirely.
#
# Architecture in production:
#   Browser → Amplify (/api/* rewrite) → CloudFront (HTTPS) → Elastic Beanstalk (HTTP) → MongoDB Atlas
#
# Amplify console setup (App settings → Rewrites and redirects):
#   Source:  /api/<*>
#   Target:  https://d3f5tqypqusci7.cloudfront.net/api/<*>
#   Type:    200 (Rewrite / Proxy)  ← must be 200, NOT a redirect
#
VITE_API_URL=
