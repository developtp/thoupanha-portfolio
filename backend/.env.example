# Copy this file to .env.local for local dev, or set these as env vars in Elastic Beanstalk.

PORT=5000

# MongoDB Atlas connection string — replace <password> with your real password.
MONGO_URI=mongodb+srv://thoupanha:<password>@cluster0.y0q6q0w.mongodb.net/?appName=Cluster0

# 6-digit admin PIN for the dashboard login.
ADMIN_PIN=123456

# Comma-separated list of allowed frontend origins (your Amplify app URL).
# Leave empty during local dev to allow all origins.
# Example: ALLOWED_ORIGINS=https://main.d1234abcd.amplifyapp.com
ALLOWED_ORIGINS=
